{
  "name": "real-estate-analyzer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "description": "Buy-and-hold real estate investing analysis — formulas, scenarios, reports.",
  "scripts": {
    "pretest": "npm rebuild better-sqlite3 --silent",
    "test": "vitest run",
    "test:watch": "vitest",
    "precli": "npm rebuild better-sqlite3 --silent",
    "cli": "node src/cli.js",
    "predev": "electron-rebuild -f -w better-sqlite3",
    "dev": "electron-vite dev",
    "prebuild": "electron-rebuild -f -w better-sqlite3",
    "build": "electron-vite build",
    "prestart": "electron-rebuild -f -w better-sqlite3",
    "start": "electron-vite preview",
    "rebuild:node": "npm rebuild better-sqlite3",
    "rebuild:electron": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^41.2.2",
    "electron-vite": "^2.3.0",
    "vite": "^5.4.21",
    "vitest": "^2.1.8"
  }
}
